{
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true
    },
    "autoDocstring.generateDocstringOnEnter": false,
    "autoDocstring.includeExtendedSummary": true,
    "autoDocstring.startOnNewLine": true,
    "C_Cpp.clang_format_sortIncludes": true,
    "C_Cpp.clang_format_style": "{ BasedOnStyle: LLVM, IndentWidth: 4, BreakBeforeBraces: Stroustrup, ColumnLimit: 0, SpacesBeforeTrailingComments: 2, PointerAlignment: Right }",
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.doxygen.generatedStyle": "/**",
    "C_Cpp.inlayHints.autoDeclarationTypes.enabled": true,
    "C_Cpp.inlayHints.autoDeclarationTypes.showOnLeft": true,
    "C_Cpp.inlayHints.parameterNames.enabled": true,
    "C_Cpp.inlayHints.parameterNames.suppressWhenArgumentContainsName": false,
    "C_Cpp.inlayHints.referenceOperator.enabled": true,
    "C_Cpp.vcFormat.indent.caseContentsWhenBlock": true,
    "C_Cpp.vcFormat.indent.caseLabels": true,
    "cmake.configureOnOpen": false,
    "cmake.options.statusBarVisibility": "compact",
    "cSpell.diagnosticLevel": "Hint",
    "cSpell.language": "en,en-US",
    "css.format.spaceAroundSelectorSeparator": true,
    "dotnetAcquisitionExtension.enableTelemetry": false,
    "editor.acceptSuggestionOnEnter": "off",
    "editor.accessibilitySupport": "off",
    "editor.copyWithSyntaxHighlighting": false,
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorSurroundingLines": 2,
    "editor.cursorWidth": 2,
    "editor.dragAndDrop": false,
    "editor.fontFamily": "SF Mono, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 12,
    "editor.fontWeight": "normal",
    "editor.formatOnSave": true,
    "editor.hover.above": false,
    "editor.inlayHints.fontSize": 9,
    "editor.inlayHints.padding": true,
    "editor.inlineSuggest.showToolbar": "always",
    "editor.lightbulb.experimental.showAiIcon": "on",
    "editor.minimap.enabled": false,
    "editor.padding.bottom": 10,
    "editor.padding.top": 10,
    "editor.renderWhitespace": "all",
    "editor.rulers": [
        88
    ],
    "editor.scrollbar.horizontal": "visible",
    "editor.scrollbar.vertical": "visible",
    "editor.tabCompletion": "on",
    "editor.tabSize": 4,
    "editor.wordWrap": "on",
    "explorer.compactFolders": false,
    "explorer.confirmUndo": "verbose",
    "extensions.autoUpdate": "onlyEnabledExtensions",
    "files.autoSave": "afterDelay",
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "flake8.args": [
        "--max-line-length=140",
        "--ignore=E203,E231,E262,E265,E501,W503,E722"
    ],
    "git.autofetch": true,
    "gitblame.inlineMessageEnabled": true,
    "gitblame.inlineMessageFormat": "// ${author.name}: \"${commit.summary}\" (${time.ago})",
    "gitblame.inlineMessageMargin": 8,
    "gitblame.statusBarMessageClickAction": "Open git show",
    "gitblame.statusBarMessageFormat": "${author.name}: \"${commit.summary}\" (${time.ago})",
    "github.copilot.advanced": {},
    "github.copilot.chat.localeOverride": "en",
    "github.copilot.chat.welcomeMessage": "always",
    "github.copilot.enable": {
        "markdown": "true"
    },
    "html.format.indentHandlebars": true,
    "html.format.indentInnerHtml": true,
    "html.format.wrapLineLength": 0,
    "isort.args": [
        "--profile",
        "black"
    ],
    "json.sortOnSave.enable": true,
    "jupyter.askForKernelRestart": false,
    "jupyter.disableJupyterAutoStart": true,
    "jupyter.experiments.enabled": false,
    "jupyter.interactiveWindow.textEditor.autoAddNewCell": false,
    "jupyter.interactiveWindow.textEditor.autoMoveToNextCell": false,
    "jupyter.widgetScriptSources": [
        "jsdelivr.com",
        "unpkg.com"
    ],
    "less.format.spaceAroundSelectorSeparator": true,
    "livePreview.autoRefreshPreview": "On Changes to Saved Files",
    "liveServer.settings.CustomBrowser": "firefox:PrivateMode",
    "markdown.editor.pasteUrlAsFormattedLink.enabled": "smart",
    "markdown.extension.tableFormatter.normalizeIndentation": true,
    "markdown.occurrencesHighlight.enabled": true,
    "notebook.cellFocusIndicator": "border",
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "notebook.cellToolbarVisibility": "hover",
    "notebook.consolidatedOutputButton": false,
    "notebook.formatOnCellExecution": true,
    "notebook.formatOnSave.enabled": true,
    "notebook.insertFinalNewline": true,
    "notebook.lineNumbers": "on",
    "notebook.navigation.allowNavigateToSurroundingCells": false,
    "notebook.output.scrolling": true,
    "notebook.output.textLineLimit": 60,
    "notebook.output.wordWrap": true,
    "notebook.showFoldingControls": "always",
    "problems.showCurrentInStatus": true,
    "python.analysis.autoFormatStrings": true,
    "python.analysis.autoImportCompletions": false,
    "python.analysis.completeFunctionParens": true,
    "python.analysis.inlayHints.callArgumentNames": "partial",
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.pytestParameters": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.experiments.enabled": false,
    "python.terminal.activateEnvInCurrentTerminal": true,
    "rainbow_csv.rbql_with_headers_by_default": true,
    "references.preferredLocation": "view",
    "remote.autoForwardPorts": false,
    "search.showLineNumbers": true,
    "search.smartCase": true,
    "security.workspace.trust.enabled": false,
    "security.workspace.trust.untrustedFiles": "open",
    "telemetry.telemetryLevel": "error",
    "terminal.external.osxExec": "iTerm.app",
    "terminal.integrated.allowChords": false,
    "terminal.integrated.confirmOnKill": "never",
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorWidth": 2,
    "terminal.integrated.enablePersistentSessions": true,
    "terminal.integrated.hideOnStartup": "whenEmpty",
    "terminal.integrated.tabs.showActions": "always",
    "update.mode": "start",
    "window.commandCenter": false,
    "window.confirmBeforeClose": "keyboardOnly",
    "window.nativeTabs": true,
    "window.newWindowDimensions": "maximized",
    "window.restoreFullscreen": true,
    "window.restoreWindows": "all",
    "window.titleBarStyle": "native",
    "window.zoomLevel": -0.5,
    "workbench.colorTheme": "Monokai Night",
    "workbench.commandPalette.preserveInput": true,
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.openPositioning": "last",
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "workbench.editor.restoreViewState": true,
    "workbench.editor.tabActionCloseVisibility": false,
    "workbench.editor.tabCloseButton": "off",
    "workbench.enableExperiments": false,
    "workbench.iconTheme": "vscode-great-icons",
    "workbench.productIconTheme": "macos-modern",
    "workbench.sideBar.location": "right",
    "workbench.startupEditor": "newUntitledFile",
    "workbench.editor.enablePreview": false
}
