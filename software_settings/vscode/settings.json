{
    "security.workspace.trust.untrustedFiles": "open",
    "terminal.integrated.confirmOnKill": "never",
    "telemetry.telemetryLevel": "off",
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": true,
    "security.workspace.trust.enabled": false,
    "files.trimTrailingWhitespace": true,
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 7000,
    "workbench.enableExperiments": false,
    "jupyter.experiments.enabled": false,
    "editor.cursorSurroundingLines": 2,
    "editor.acceptSuggestionOnEnter": "off",
    "files.insertFinalNewline": true,
    "editor.renderWhitespace": "all",
    "editor.accessibilitySupport": "off",
    "editor.dragAndDrop": false,
    "editor.padding.top": 10,
    "editor.scrollbar.horizontal": "visible",
    "editor.scrollbar.vertical": "visible",
    "editor.cursorWidth": 2,
    "window.newWindowDimensions": "maximized",
    "python.experiments.enabled": false,
    "update.mode": "start",
    "extensions.autoUpdate": "onlyEnabledExtensions",
    "workbench.colorTheme": "Monokai Night",
    "editor.tabCompletion": "on",
    "python.analysis.completeFunctionParens": true,
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.tabCloseButton": "off",
    "python.linting.flake8Args": [
        "--max-line-length=140",
        "--ignore=E51,E231,E265,E262,E501,E722,W605"
    ],
    "python.linting.flake8Enabled": true,
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "cSpell.diagnosticLevel": "Hint",
    "notebook.cellToolbarVisibility": "hover",
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "workbench.sideBar.location": "right",
    "zenMode.hideTabs": false,
    "editor.wordWrap": "on",
    "html.format.wrapLineLength": 0,
    "editor.parameterHints.enabled": false,
    "python.analysis.autoImportCompletions": false,
    "terminal.integrated.tabs.hideCondition": "never",
    "terminal.integrated.tabs.showActions": "always",
    "terminal.integrated.tabs.showActiveTerminal": "never",
    "editor.padding.bottom": 10,
    "git.autofetch": true,
    "python.formatting.provider": "black",
    "editor.formatOnSave": true,
    "python.formatting.blackPath": "/opt/homebrew/bin/black",
    "python.linting.flake8Path": "/opt/homebrew/bin/flake8",
    "terminal.external.osxExec": "iTerm.app",
    "terminal.integrated.inheritEnv": false,
    "notebook.consolidatedOutputButton": false,
    "notebook.showFoldingControls": "always",
    "workbench.startupEditor": "none",
    "jupyter.askForKernelRestart": false,
    "notebook.cellFocusIndicator": "border",
    "jupyter.newCellOnRunLast": false,
    "html.autoClosingTags": false,
    "editor.rulers": [
        88
    ],
    "search.mode": "reuseEditor",
    "livePreview.autoRefreshPreview": "On Changes to Saved Files",
    "liveServer.settings.CustomBrowser": "firefox:PrivateMode",
    "workbench.editor.enablePreview": false,
    "editor.minimap.enabled": false,
    "terminal.integrated.shellIntegration.enabled": false,
    "cSpell.language": "en,en-US",
    "autoDocstring.includeExtendedSummary": true,
    "autoDocstring.startOnNewLine": true,
    "workbench.editor.openPositioning": "last",
    "editor.autoClosingQuotes": "never",
    "C_Cpp.clang_format_fallbackStyle": "{BasedOnStyle: LLVM, IndentWidth: 4}"
}
